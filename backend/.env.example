# MajorScout environment variables
# Copy to backend/.env and fill in values.

SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# Google OAuth (Authorized redirect URI: http://localhost:5173/api/auth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated Gmail addresses that receive admin + premium access
ADMIN_EMAILS=you@gmail.com

# Stripe subscription
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# OpenAI (gpt-4o-mini by default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
